# Virtual_stained_Her2 – exclude from repo (do not push)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# Data & checkpoints (download separately)
ckpt/
models_train/

# Datasets: ignore full data, keep sample (e.g. 4 PNGs in valA, valB)
datasets/*
!datasets/BCI_HER2_sample/
!datasets/BCI_HER2_sample/**

# Results: ignore other runs, keep sample stain2stain (e.g. 4 PNGs)
results/*
!results/stain2stain/
!results/stain2stain/**

# Stain2stain – not needed in repo (legacy)
stain2stain/environment.yml
stain2stain/README.md
stain2stain/gitignore
stain2stain/__int__.py
stain2stain/__int__ copy.py

# IDE / OS
.idea/
.vscode/
.DS_Store
*.swp
*~
