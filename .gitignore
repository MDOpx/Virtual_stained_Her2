# Virtual_stained_Her2 – exclude from repo (do not push)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# Data & checkpoints (download separately)
ckpt/
models_train/

# Datasets: ignore full data, keep sample (e.g. 4 PNGs in valA, valB)
datasets/*
!datasets/BCI_HER2_sample/
!datasets/BCI_HER2_sample/**

# Results: ignore other runs, keep sample reconstruction (e.g. 4 PNGs)
results/*
!results/reconstruction/
!results/reconstruction/**

# Recon – not needed for inference repo
recon/environment.yml
recon/README.md
recon/gitignore
recon/__int__.py
recon/__int__ copy.py

# IDE / OS
.idea/
.vscode/
.DS_Store
*.swp
*~
